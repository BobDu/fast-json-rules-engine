{
  "name": "fast-json-rules-engine",
  "version": "0.0.0",
  "description": "Fast, compiled, zero-dependency rules engine compatible with the json-rules-engine JSON rule format",
  "keywords": [
    "rules",
    "rules-engine",
    "rule-engine",
    "json-rules-engine",
    "rule",
    "engine",
    "compiler",
    "fast"
  ],
  "license": "MIT",
  "author": "BobDu <i@bobdu.cc>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BobDu/fast-json-rules-engine.git"
  },
  "homepage": "https://github.com/BobDu/fast-json-rules-engine#readme",
  "bugs": {
    "url": "https://github.com/BobDu/fast-json-rules-engine/issues"
  },
  "engines": {
    "node": ">=14"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "node test/run.js",
    "bench": "npm run build && node bench/bench.mjs"
  },
  "devDependencies": {
    "@types/node": "^20",
    "json-rules-engine": "6.6.0",
    "jsonpath-plus": "^7.2.0",
    "tsdown": "^0.22.3",
    "typescript": "^5"
  }
}
