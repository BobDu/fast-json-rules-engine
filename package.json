{
  "name": "fast-json-rules-engine",
  "version": "0.0.0-development",
  "description": "Compiled, synchronous, zero-dependency rules engine compatible with the json-rules-engine rule format — compile once, no Promise overhead per run.",
  "keywords": [
    "rules",
    "rules-engine",
    "rule-engine",
    "json-rules-engine",
    "rule",
    "engine",
    "compiler",
    "fast",
    "business-rules",
    "zero-dependency",
    "json"
  ],
  "license": "MIT",
  "author": "BobDu <i@bobdu.cc>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BobDu/fast-json-rules-engine.git"
  },
  "homepage": "https://github.com/BobDu/fast-json-rules-engine#readme",
  "bugs": {
    "url": "https://github.com/BobDu/fast-json-rules-engine/issues"
  },
  "engines": {
    "node": ">=14"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts --clean --platform node --target node14",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run test:dist",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "npm run build && eslint dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:contract": "npm run build && node test/dist-smoke.cjs && node test/dist-smoke.mjs && vitest run --config vitest.dist.config.ts",
    "test:types": "attw --pack .",
    "test:dist": "npm run test:contract && npm run test:types",
    "bench": "npm run build && node bench/bench.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@fast-check/vitest": "^0.4.1",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-n": "^18.2.1",
    "fast-check": "^4.8.0",
    "json-rules-engine": "6.6.0",
    "jsonpath-plus": "^10.4.0",
    "tsdown": "^0.22.7",
    "typescript": "^7",
    "vitest": "^4.1.9"
  }
}
